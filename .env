# =====================
# App
# =====================
APP_NAME=Enterprise Knowledge Base
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# =====================
# Database
# =====================
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/enterprise_kb?charset=utf8mb4

# =====================
# Embedding
# =====================
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# =====================
# RAG
# =====================
TOP_K=3
SCORE_THRESHOLD=1.2

# =====================
# Default LLM
# =====================
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_MODEL_LEVEL=default
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

# =====================
# Qwen / DashScope
# =====================
DASHSCOPE_API_KEY=sk-db6b688b13b14d20a17576d6fd344c70
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

QWEN_FAST_MODEL=qwen-turbo
QWEN_DEFAULT_MODEL=qwen-plus
QWEN_STRONG_MODEL=qwen-max

# 兼容旧字段，可留可不留
QWEN_MODEL=qwen-plus

# =====================
# MIMO
# =====================
MIMO_API_KEY=sk-chkfvz9s38io84f1tfjp78lvyohmegv8r86ip82uhraw2gv3
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

MIMO_FAST_MODEL=mimo-v2-omni
