# =====================
# App
# =====================
APP_NAME=Enterprise Knowledge Base
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# =====================
# Database
# =====================
# Current project uses MySQL in runtime.
# Format:
# mysql+pymysql://<user>:<password>@<host>:<port>/<database>?charset=utf8mb4
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/enterprise_kb?charset=utf8mb4

# =====================
# Embedding
# =====================
# The app first tries to load this model locally.
# If it is unavailable, backend/vector_store.py falls back to LocalHashEmbeddings.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# =====================
# RAG
# =====================
TOP_K=3
SCORE_THRESHOLD=1.2

# =====================
# Default LLM
# =====================
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_MODEL_LEVEL=default
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

# =====================
# Qwen / DashScope
# =====================
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

QWEN_FAST_MODEL=qwen-turbo
QWEN_DEFAULT_MODEL=qwen-plus
QWEN_STRONG_MODEL=qwen-max

# Compatibility field used by older code paths if needed.
QWEN_MODEL=qwen-plus

# =====================
# MIMO
# =====================
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

MIMO_FAST_MODEL=mimo-v2-omni
MIMO_DEFAULT_MODEL=mimo-v2.5
MIMO_STRONG_MODEL=mimo-v2.5-pro
